    "hyprland/workspaces": {
        "all-outputs": true,
        "format": "{name}",
        "on-scroll-up": "hyprctl dispatch workspace e+1 1>/dev/null",
        "on-scroll-down": "hyprctl dispatch workspace e-1 1>/dev/null"
    },

    "hyprland/window": {
        "max-length": 160,
        "separate-outputs": true,
        "tooltip": false,
        "icon": true
    },

    "mpris": {
        "format": "{player_icon} {artist} - {title} {status_icon}",
        "format-paused": "{player_icon} {artist} - {title} {status_icon}",
        "tooltip-format": "{artist} - {title} - {album} {length}",
        "player-icons": {
            "default": "пЃ‹"
        },
        "status-icons": {
            "playing": "пЃ‹",
            "paused": "пЃЊ",
            "stopped": "пЃЌ"
        },
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl stop"
    },

    "pulseaudio": {
        "scroll-step": 5, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}пЉ” {format_source}",
        "format-bluetooth-muted": "у°…¶ {icon}пЉ” {format_source}",
